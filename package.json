{
  "name": "ptd-site-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "Uptime monitor for PT sites, driven by GitHub Actions and Astro",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "monitor": "node scripts/monitor.mjs",
    "update-source": "node scripts/update-source.mjs",
    "cleanup": "node scripts/cleanup.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  },
  "dependencies": {
    "astro": "^5.0.0",
    "p-queue": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
