---
export interface Props {
  data: Array<{ timestamp: string; latency: number | null }>;
  height?: number;
}

const { data, height = 180 } = Astro.props;

const now = Date.now();
const windowMs = 7 * 24 * 60 * 60 * 1000;
const windowStart = now - windowMs;
const bucketCount = 168;
const bucketMs = windowMs / bucketCount;

const buckets: number[] = new Array(bucketCount).fill(0);
const counts: number[] = new Array(bucketCount).fill(0);

for (const d of data) {
  const ts = new Date(d.timestamp).getTime();
  const elapsed = now - ts;
  if (elapsed < 0 || elapsed > windowMs) continue;
  const idx = Math.floor(elapsed / bucketMs);
  if (idx >= 0 && idx < bucketCount && d.latency !== null) {
    buckets[idx] += d.latency;
    counts[idx]++;
  }
}

// Build points: skip buckets with no data (don't force to 0)
// [0]=oldest → [last]=newest
const pts: { x: number; y: number }[] = [];
for (let i = bucketCount - 1; i >= 0; i--) {
  if (counts[i] > 0) {
    const avg = Math.round(buckets[i] / counts[i]);
    pts.push({ x: (bucketCount - i - 1) / bucketCount, y: avg });
  }
}

const validMax = pts.length > 0 ? Math.max(...pts.map((p) => p.y), 1) : 1;

const pad = { t: 22, r: 12, b: 26, l: 12 };
const cw = 800;
const ch = height;
const tw = cw + pad.l + pad.r;
const th = ch + pad.t + pad.b;

function sx(x: number) { return pad.l + x * cw; }
function sy(v: number) { return pad.t + ch - (v / validMax) * ch; }

function buildPath(): string {
  if (pts.length === 0) return "";
  let d = `M${sx(pts[0].x)},${sy(pts[0].y)}`;
  for (let i = 0; i < pts.length - 1; i++) {
    const x0 = sx(pts[i].x), y0 = sy(pts[i].y);
    const x3 = sx(pts[i + 1].x), y3 = sy(pts[i + 1].y);
    const dx = (x3 - x0) / 3;
    d += ` C${x0 + dx},${y0} ${x3 - dx},${y3} ${x3},${y3}`;
  }
  return d;
}

const line = buildPath();
const firstX = pts.length > 0 ? pts[0].x : 0;
const lastX = pts.length > 0 ? pts[pts.length - 1].x : 1;
const area = pts.length > 0 ? `${line} L${sx(lastX)},${sy(0)} L${sx(firstX)},${sy(0)} Z` : "";

// Calculate midnight markers for each day in the window
function getMidnights(): { x: number; label: string }[] {
  const result = [];
  const d = new Date(windowStart);
  // Advance to next midnight
  d.setHours(24, 0, 0, 0);
  while (d.getTime() <= now) {
    const x = (d.getTime() - windowStart) / windowMs;
    const label = `${String(d.getMonth() + 1).padStart(2, "0")}/${String(d.getDate()).padStart(2, "0")}`;
    result.push({ x, label });
    d.setDate(d.getDate() + 1);
  }
  return result;
}

const midnights = getMidnights();

function fmtLat(ms: number): string {
  return ms >= 1000 ? `${(ms / 1000).toFixed(1)}s` : `${ms}ms`;
}
---

<div class="chart-wrap">
  <svg
    viewBox={`0 0 ${tw} ${th}`}
    width="100%"
    height={th}
    role="img"
    aria-label="7-day latency chart"
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--color-up)" stop-opacity="0.25" />
        <stop offset="100%" stop-color="var(--color-up)" stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- Horizontal grid -->
    <line x1={pad.l} y1={sy(0)} x2={sx(1)} y2={sy(0)} stroke="var(--color-border)" stroke-width="0.5" />
    <line x1={pad.l} y1={sy(validMax / 2)} x2={sx(1)} y2={sy(validMax / 2)} stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2,2" />
    <line x1={pad.l} y1={sy(validMax)} x2={sx(1)} y2={sy(validMax)} stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2,2" />

    <!-- Midnight vertical markers -->
    {midnights.map((m) => (
      <>
        <line x1={sx(m.x)} y1={sy(0)} x2={sx(m.x)} y2={sy(validMax)} stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2,2" opacity="0.6" />
        <text x={sx(m.x)} y={th - 2} fill="var(--color-text-secondary)" font-size="9" text-anchor="middle">{m.label}</text>
      </>
    ))}

    {validMax > 0 && <path d={area} fill="url(#areaGrad)" />}
    <path d={line} fill="none" stroke="var(--color-up)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />

    <text x={pad.l} y={pad.t - 4} fill="var(--color-text-secondary)" font-size="10">{fmtLat(validMax)}</text>
    <text x={pad.l} y={sy(0) - 2} fill="var(--color-text-secondary)" font-size="10">0ms</text>
  </svg>
</div>

<style>
  .chart-wrap {
    width: 100%;
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    padding: 0.5rem;
  }

  .chart-wrap svg {
    display: block;
    width: 100%;
  }
</style>
